<Window x:Class="NtpTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NtpTimer"
        mc:Ignorable="d"
        Title="NTP Timer" Height="320" Width="760"
        Background="#FF000000"
        MinHeight="220" MinWidth="520"
        WindowStartupLocation="CenterScreen"
        FontFamily="Consolas">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 날짜 -->
        <TextBlock x:Name="DateText" Grid.Row="0"
                   Text="----.--.-- (---)"
                   Foreground="#FF7FFFD4" FontSize="26"
                   HorizontalAlignment="Center" Margin="0,0,0,4"/>

        <!-- 시:분:초.ms 메인 표시 -->
        <Viewbox Grid.Row="1" Stretch="Uniform" Margin="0,4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="TimeText" Text="00:00:00"
                           Foreground="#FF00FF7F" FontWeight="Bold"/>
                <TextBlock x:Name="MsText" Text=".000"
                           Foreground="#FF39FF14" FontWeight="Bold"/>
            </StackPanel>
        </Viewbox>

        <!-- 상태/오프셋 -->
        <TextBlock x:Name="StatusText" Grid.Row="2"
                   Text="NTP 동기화 중..."
                   Foreground="#FFB0B0B0" FontSize="14"
                   HorizontalAlignment="Center" Margin="0,8,0,0"/>

        <!-- 컨트롤 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,12,0,0">
            <CheckBox x:Name="UtcCheck" Content="UTC 표시"
                      Foreground="#FFB0B0B0" VerticalAlignment="Center"
                      Margin="0,0,16,0" Checked="Utc_Changed" Unchecked="Utc_Changed"/>
            <Button x:Name="ResyncButton" Content="재동기화"
                    Padding="14,4" Click="Resync_Click"
                    Background="#FF1E1E1E" Foreground="#FF7FFFD4"
                    BorderBrush="#FF3A3A3A"/>
        </StackPanel>
    </Grid>
</Window>
